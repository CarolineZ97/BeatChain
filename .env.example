# Environment Variables for BeatChain

# Network RPC URLs
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_RPC_URL=https://polygon-rpc.com

# Deployer private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# PolygonScan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# USDC token address on Polygon Mumbai testnet
USDC_ADDRESS=0x0FA8781a83E46826621b3BC094Ea2A0212e71B23

# USDC token address on Polygon mainnet
# USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# Platform admin wallet address
PLATFORM_ADMIN=your_platform_admin_address_here

# Gas reporting
REPORT_GAS=true
